# Recommended zero-cost setup
GROQ_API_KEY=
# Optional override; defaults to llama-3.1-8b-instant
GROQ_MODEL=

# Optional cloud fallbacks
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Optional research submission proxy
# Explicit default hosted backend
RESEARCH_BACKEND=supabase
AIRA_ALLOW_PUBLIC_RESEARCH_SUBMISSIONS=false

# Preferred hosted backend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE=aira_submissions
SUPABASE_CHECKS_TABLE=aira_submission_checks

# Research schema v2 defaults
AIRA_SAMPLE_NAME=
AIRA_SAMPLE_VERSION=v1
AIRA_ATTRIBUTION_CLASS=unknown
AIRA_SOURCE_ID=
AIRA_SOURCE_KIND=
AIRA_SCANNER_VERSION=1.2.0
AIRA_RULESET_VERSION=1.2.0

# Local/CI backend
AIRA_RESEARCH_JSONL=

# Airtable compatibility fallback
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Submissions
AIRTABLE_TOKEN=
